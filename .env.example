# MarketScout Environment Variables
# Copy this to .env and fill in your values

# Finnhub API - Free tier: 60 calls/minute
# Sign up at: https://finnhub.io/
# No API key needed for basic scanning (uses simulated data)
FINNHUB_API_KEY=

# Discord Webhook URL
# Get from: Discord Server → Channel Settings → Integrations → Webhooks → New Webhook
# Copy the webhook URL here
DISCORD_WEBHOOK_URL=

# Alert threshold (default: 6.0)
# Only send Discord alerts for candidates with score >= threshold
ALERT_THRESHOLD=6.0
